{
  "applicationId": "js.neutralino.markup-img",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "url": "/index.html",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": false
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "server.*"
  ],
  "modes": {
    "window": {
      "title": "markup-img",
      "width": 1920,
      "height": 1080,
      "hidden": true
    }
  },
  "cli": {
    "binaryName": "neutralino",
    "resourcesPath": "/resources/",
    "clientLibrary": "/resources/neutralino.js",
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  }
}